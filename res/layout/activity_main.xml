<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kalkulator Volume"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"
        android:textColor="#333333"/>

    <EditText
        android:id="@+id/inputAngka"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Masukkan Sisi / Jari-jari (r)"
        android:inputType="numberDecimal"
        android:layout_marginBottom="8dp"
        android:padding="12dp"
        android:background="@android:drawable/editbox_background"/>

    <EditText
        android:id="@+id/inputTinggi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Masukkan Tinggi (Khusus Tabung)"
        android:inputType="numberDecimal"
        android:layout_marginBottom="20dp"
        android:padding="12dp"
        android:background="@android:drawable/editbox_background"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pilih Jenis Pi (π):"
        android:layout_marginTop="10dp"/>

    <RadioGroup
        android:id="@+id/rgPi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="15dp">

        <RadioButton
            android:id="@+id/rbDesimal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3.14"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rbPecahan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="22/7"
            android:layout_marginStart="20dp" />
    </RadioGroup>

    <Button
        android:id="@+id/btnKubus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hitung Volume Kubus"
        android:layout_marginBottom="8dp"
        android:textAllCaps="false"/>

    <Button
        android:id="@+id/btnTabung"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hitung Volume Tabung"
        android:layout_marginBottom="8dp"
        android:textAllCaps="false"/>

    <Button
        android:id="@+id/btnBola"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hitung Volume Bola"
        android:layout_marginBottom="24dp"
        android:textAllCaps="false"/>

    <TextView
        android:id="@+id/tvHasil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hasil: 0"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="#2E7D32"/>
</LinearLayout>